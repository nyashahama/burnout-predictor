# Database — required
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/burnout_predictor?sslmode=disable

# JWT signing secret — required
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET=

# Email via Resend (https://resend.com) — optional
# Leave blank to disable all transactional emails.
RESEND_API_KEY=
# Sender address shown in the From header (must be a verified domain in Resend).
EMAIL_FROM=Overload <noreply@yourdomain.com>

# AI recovery plans via OpenAI — optional
# Leave blank to fall back to rule-based recovery plans only.
OPENAI_API_KEY=

# Paddle billing webhooks — optional
# Find in Paddle dashboard → Developer → Notifications → secret key.
# Leave blank to skip signature verification (dev only).
PADDLE_WEBHOOK_SECRET=

# Frontend base URL — used to construct email links (verify, reset password).
# Defaults to https://overload.app if not set.
APP_URL=https://overload.app

# HTTP server — optional, defaults to 8080
PORT=8080
