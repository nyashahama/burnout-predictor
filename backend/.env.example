# Required
DATABASE_URL=postgres://user:password@localhost:5432/burnout_predictor
JWT_SECRET=change-me-in-production

# Server
PORT=8080

# CORS — space-separated list of allowed origins (defaults to no CORS headers if unset)
CORS_ORIGIN=http://localhost:3000

# Email (Resend) — optional; email sending disabled if unset
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Overload <noreply@overload.app>

# AI (OpenAI) — optional; AI features disabled if unset
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paddle billing — optional; webhook signature verification disabled if unset
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App base URL (used in email links)
APP_URL=https://overload.app
